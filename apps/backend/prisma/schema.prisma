generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PATIENT
  DOCTOR
}

enum Urgency {
  NORMAL
  URGENT
  IMPORTANT
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?
}

model PatientProfile {
  patientId   String @id
  age         Int
  contactInfo String
  bloodGroup  String
  address     String

  user         User          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointments Appointment[]
}

model DoctorProfile {
  doctorId      String @id
  age           Int
  experience    Int
  speciality    String
  clinicAddress String
  fees          Float
  timings       String
  phone         String?
  receptionPhone String?

  user              User               @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  availabilitySlots AvailabilitySlot[]
  appointments      Appointment[]
}

model AvailabilitySlot {
  id        String   @id @default(uuid())
  doctorId  String
  date      DateTime @db.Date
  startTime String
  endTime   String
  isBooked  Boolean  @default(false)

  doctor      DoctorProfile @relation(fields: [doctorId], references: [doctorId], onDelete: Cascade)
  appointment Appointment?
}

model Appointment {
  id        String            @id @default(uuid())
  patientId String
  doctorId  String
  slotId    String            @unique
  reason    String
  urgency   Urgency           @default(NORMAL)
  status    AppointmentStatus @default(PENDING)
  createdAt DateTime          @default(now())
  isRescheduled Boolean @default(false)

  patient PatientProfile  @relation(fields: [patientId], references: [patientId], onDelete: Cascade)
  doctor  DoctorProfile   @relation(fields: [doctorId], references: [doctorId], onDelete: Cascade)
  slot    AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
}
